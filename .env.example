# ── Server ──────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────
# Local:   mongodb://localhost:27017/paybackpal
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/paybackpal
MONGODB_URI=mongodb://localhost:27017/paybackpal

# ── JWT ──────────────────────────────────────────
# Change this to a long random string in production!
JWT_SECRET=paybackpal_super_secret_key_change_in_production
JWT_EXPIRE=7d

# ── Email (Nodemailer / Gmail) ───────────────────
# Use an App Password (not your real password) with Gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=PayBackPal <your-email@gmail.com>

# ── Frontend origin (CORS) ───────────────────────
CLIENT_URL=http://localhost:8080
